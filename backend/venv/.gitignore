# ===== BACKEND =====

# Virtual environment — never push this (hundreds of MB, machine-specific)
backend/venv/

# Python cache files — auto-generated, not needed
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Django sensitive config
backend/.env
*.env

# Database files
*.sqlite3
*.db

# Django static/media files
backend/staticfiles/
backend/media/

# Migration files (optional — some teams track these, some don't)
# backend/*/migrations/*.py  ← uncomment if you want to exclude

# ===== FRONTEND =====

# Node modules — never push this (massive folder, auto-restored with npm install)
frontend/node_modules/
frontend/crm_frontend/node_modules/

# Vite build output
frontend/dist/
frontend/crm_frontend/dist/

# Frontend env files
frontend/.env
frontend/crm_frontend/.env
frontend/crm_frontend/.env.local
frontend/crm_frontend/.env.production

# ===== GENERAL =====

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/settings.json
.idea/

# Logs
*.log
npm-debug.log*